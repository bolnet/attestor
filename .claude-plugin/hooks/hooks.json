{
  "hooks": [
    {
      "event": "SessionStart",
      "command": "memwright hook session-start",
      "timeout_ms": 10000,
      "description": "Inject relevant memories into session context"
    },
    {
      "event": "PostToolUse",
      "command": "memwright hook post-tool-use",
      "timeout_ms": 5000,
      "description": "Capture observations from tool usage"
    },
    {
      "event": "Stop",
      "command": "memwright hook stop",
      "timeout_ms": 10000,
      "description": "Summarize session and store key decisions"
    }
  ]
}
